{
  "name": "my-electron-app",
  "version": "1.0.0",
  "description": "Hello World!",
  "main": "main.js",
  "scripts": {
    "start": "electron --inspect=9229 .",
    "build": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "sunshine",
  "license": "MIT",
  "build": {
    "appId": "com.yourapp.test",
    "productName": "SherpaTest",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/sherpa-onnx-node/**"
    ],
    "extraResources": [
      {
        "from": "node_modules/sherpa-onnx-node/",
        "to": "node_modules/sherpa-onnx-node/",
        "filter": [
          "**/*.node",
          "**/*.js",
          "**/*.json"
        ]
      },
      {
        "from": "models",
        "to": "app/models"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": true
  },
  "dependencies": {
    "form-data": "^4.0.5",
    "naudiodon2": "^2.5.0",
    "node-fetch": "^2.7.0",
    "pinyin": "^4.0.0",
    "sherpa-onnx-node": "^1.12.35",
    "sherpa-onnx-win-x64": "^1.12.35",
    "speaker": "^0.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}